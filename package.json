{
  "name": "webhook-task-pipeline",
  "version": "1.0.0",
  "description": "Webhook-driven task processing pipeline with pg-boss and PostgreSQL",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "worker": "node dist/worker/worker.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker/worker.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "db:create": "node scripts/create-database.cjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "webhook",
    "pg-boss",
    "express",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.6",
    "sequelize": "^6.37.5",
    "uuid": "^11.0.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  }
}
